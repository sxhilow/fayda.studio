---
import CaseStudyHeader from "../components/molecules/CaseStudyHeader.astro";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
const { title } = frontmatter;


---

<Layout title={title + " - Fayda Studio"} description="...">
  <section class="px-2 space-y-2">
    <CaseStudyHeader frontmatter={frontmatter} />
    
    <div class="max-w-6xl mx-auto text-neutral prose prose-invert prose-xl prose-img:rounded-xl prose-h2:text-primary-orange leading-tight prose-strong:text-neutral mb-12 md:mb-32 max-lg:px-3">
      <slot />
    </div>

    
  </section>
</Layout>