---
import { Image } from "astro:assets"
import Down from "../../assets/icons/Down.svg"

const { question, answer } = Astro.props
---

<details class="group border-b border-neutral3 py-3  cursor-pointer">

    <!-- WebKit (Safari) show a disclosure triangle (black arrow) -->
    <summary class="list-none flex justify-between items-start text-neutral cursor-pointer [&::-webkit-details-marker]:hidden">
         
        <h1 class="text-lg flex-1 pr-4">
            {question}
        </h1>
        <div>
            <Image
                src={Down}
                alt="Icon"
                class="icon w-5 transition-transform duration-300 group-open:rotate-180"
            />
        </div>
    </summary>
    <p class="font-light mt-2 text-neutral details-content">
        {answer}
    </p>
</details>