---
import { Image } from "astro:assets";
import Down from "../../assets/icons/Down.svg";

interface Props {
    question: string;
    answer: string;
}

const { question, answer } = Astro.props;
---

<details class="group border-b border-neutral-12 py-3">
    <!-- WebKit (Safari) show a disclosure triangle (black arrow) -->
    <summary
        class="list-none flex justify-between items-start text-neutral-5 hover:text-brand-surface cursor-pointer [&::-webkit-details-marker]:hidden"
    >
        <h1 class="text-lg flex-1 pr-4">
            {question}
        </h1>
        <div>
            <Down
                class="w-5 transition-transform duration-300 group-open:rotate-180"
            />
        </div>
    </summary>
    <p class="font-light mt-2 text-neutral-5 details-content">
        {answer}
    </p>
</details>
