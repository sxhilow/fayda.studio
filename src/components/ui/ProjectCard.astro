---
import type { ProjectTag } from "@data/projects";
import { Image } from "astro:assets";
import ScrollableImage from "./ScrollableImage.astro";

interface Props {
  title: string;
  image: ImageMetadata;
  url: string;
  tags?: ProjectTag[];
  alt: string;
}

const { title, image, url, tags = ["Design"], alt } = Astro.props;
---

<a
  href={url}
  class="block group project-card-link"
  aria-label="See our designs"
  data-title={title}
  data-url={url}
>
  <div class="overflow-hidden flex flex-col gap-4">
    <ScrollableImage image={image} alt={alt}/>

    <div class="">
      <h3
        class="group-hover:text-neutral-7 text-white text-body-lg font-semibold transition duration-300"
      >
        {title}
      </h3>
      {
        tags.map((item, index) => (
          <span class="text-body-md text-neutral-7 group-hover:text-neutral-11 transition duration-300">
            {item}
            {index < tags.length - 1 && (
              <span class="mx-1" aria-hidden="true">
                •
              </span>
            )}
          </span>
        ))
      }
    </div>
  </div>
</a>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(".project-card-link").forEach((link) => {
      link.addEventListener("click", () => {
        window.posthog?.capture("project_card_clicked", {
          project_title: (link as HTMLElement).dataset.title,
          destination_url: (link as HTMLElement).dataset.url,
        });
      });
    });
  });
</script>
