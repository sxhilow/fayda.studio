---
interface Props {
    src?: string;
    isVideo?: boolean;
    testimonial?: string;
    testimonialAuthor?: string;
}

const { src, isVideo, testimonial, testimonialAuthor } =
    Astro.props;
---

<div class="flex flex-col mt-12 mb-8">
    {
        isVideo ? (
            <div class="p-8 rounded-4xl bg-neutral-12/10 border border-neutral-12 flex max-lg:flex-col gap-8">
                {src && (
                    <div class="flex-1/3">
                        <video
                            src={src as string}
                            controls
                            loop
                            playsinline
                            class="rounded-2xl w-full lg:min-w-sm"
                        />
                    </div>
                )}
                {testimonial && (
                    <div
                        class:list={[
                            "flex-2/3 flex flex-col gap-6 lg:my-6",
                            !src && "max-w-2xl mx-auto text-center",
                        ]}
                    >
                        <span class="text-h3 text-neutral-7">
                            "{testimonial}"
                        </span>
                        {testimonialAuthor && (
                            <span class="text-neutral-7">
                                — {testimonialAuthor}
                            </span>
                        )}
                    </div>
                )}
            </div>
        ) : (
            <div class="p-8 rounded-4xl bg-neutral-12/10 border border-neutral-12 flex flex-col gap-8">
                <slot/>
            </div>
        )
    }
</div>
