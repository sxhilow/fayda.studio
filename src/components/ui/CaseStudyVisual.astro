---
import { Image } from "astro:assets";

interface Props {
    src?: string;
    isVideo?: boolean;
    testimonial?: string;
    testimonialAuthor?: string;
}

const { src, isVideo, testimonial, testimonialAuthor } = Astro.props;
---

<div class="flex flex-col mt-12 mb-8">
    {
        isVideo ? (
            <div class="p-5 rounded-2xl bg-neutral-12/10 border border-neutral-12 flex max-lg:flex-col gap-8">
                {src && (
                    <div class="flex-1/3">
                        <video
                            src={src as string}
                            controls
                            loop
                            playsinline
                            class="rounded-2xl w-full lg:min-w-sm"
                        />
                    </div>
                )}
                {testimonial && (
                    <div
                        class:list={[
                            "flex-2/3 flex flex-col gap-6 lg:my-6 lg:p-5",
                            !src && "text-center",
                        ]}
                    >
                        <span class="text-h3 text-neutral-7">
                            "{testimonial}"
                        </span>
                        {testimonialAuthor && (
                            <span class="text-neutral-7">
                                — {testimonialAuthor}
                            </span>
                        )}
                    </div>
                )}
            </div>
        ) : (
            <div class="flex flex-col gap-4 md:gap-8">
                <slot name="full-top" />
                <div class="flex max-lg:flex-col items-center w-full h-auto gap-4 md:gap-8 empty:hidden">
                    <slot name="grid" />
                </div>
                <slot name="full-bottom" />
            </div>
        )
    }
</div>
