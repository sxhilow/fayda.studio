---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
    src?: ImageMetadata | string;
    alt: string;
    caption?: string;
    isVideo?: boolean;
    testimonial?: string;
    testimonialAuthor?: string;
}

const { src, alt, caption, isVideo, testimonial, testimonialAuthor } =
    Astro.props;
---

<figure class="flex flex-col my-8">
    {
        isVideo ? (
            <div class="p-8 rounded-4xl bg-neutral-12/10 border border-neutral-12 flex max-lg:flex-col gap-8">
                {src && (
                    <div class="flex-1/3">
                        <video
                            src={src as string}
                            controls
                            loop
                            playsinline
                            class="rounded-2xl w-full lg:min-w-md"
                        />
                    </div>
                )}
                {testimonial && (
                    <div
                        class:list={[
                            "flex-2/3 flex flex-col justify-between gap-6",
                            !src && "max-w-2xl mx-auto text-center",
                        ]}
                    >
                        <span class="text-h3 text-neutral-5">
                            "{testimonial}"
                        </span>
                        {testimonialAuthor && (
                            <span class="text-neutral-7 text-right">
                                — {testimonialAuthor}
                            </span>
                        )}
                    </div>
                )}
            </div>
        ) : (
            <Image
                src={src as ImageMetadata}
                alt={alt}
                inferSize
                class="rounded-4xl w-full border border-neutral-12"
            />
        )
    }
    {
        caption && (
            <figcaption class="text-neutral-7 text-caption text-center">
                {caption}
            </figcaption>
        )
    }
</figure>
