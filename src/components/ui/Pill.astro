---
import type { HTMLAttributes } from 'astro/types'

interface Props extends HTMLAttributes<'div'>{
    label: string
}

const {
    label,
    class: className
} = Astro.props

---

<div class=`${className} text-caption inline-flex rounded-full shadow-sm border border-brand-red text-neutral-5 justify-center items-center gap-2 px-4 py-2`>

    <slot name="icon"/>
    
    <span class="uppercase">
        {label}
    </span>

</div>