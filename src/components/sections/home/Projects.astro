---
import Pill from "@ui/Pill.astro"
import Case from "@icons/Case.svg"
import Section from "@ui/Section.astro"
import ProjectCard from "@ui/ProjectCard.astro"
import {projects} from "@data/projects"
---

<Section id="work">

    <div class="flex flex-col justify-center items-center gap-4">
        <Pill label="What We’re Building">
            <Case slot={"icon"} />
        </Pill>

        <div class="space-y-2 text-center">
            <h1 class="text-h1 text-brand-surface">Recent Work & Projects</h1>
            <p class="text-brand-surface font-light">
                A look at what we’ve been working on in the lab.
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-5 gap-y-10">
        {
            projects.map((project) => (
                <ProjectCard
                    title={project.title}
                    url={project.url}
                    image={project.image},
                    alt={project.alt},
                    tags={project.tags}
                />
            ))
        }
    </div>


</Section>