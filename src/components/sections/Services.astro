---
import { services } from "../../constant";
import Image from "astro/components/Image.astro";
import Right from "../../assets/icons/Right.svg"
import Button from "../atoms/Button.astro";
---

<section id="services" class="flex justify-center items-center scroll-mt-24">

    <div class=" bg-neutral2 rounded-lg w-full h-full flex flex-col justify-center items-center px-5 py-10 md:py-16 md:px-28">

        <div class="text-center -space-y-2">

            <h1 class="text-desktop-h3 text-neutral">Services</h1>
            <p class="text-lg md:text-xl font-light text-neutral">We turn ideas into high-performing and user-friendly webapps.</p>
        </div>

        <div class="flex flex-col w-full my-12 gap-1">
            {
                services.map((item) => (
                    <div 
                    class={`card bg-bg py-14 px-5 md:px-20 w-full rounded-lg flex group md:hover:bg-[var(--card-hover-bg)] transition duration-300 max-sm:duration-150 ease-in-out max-sm:gap-10`}
                    style={`--card-hover-bg: ${item.bg};`}>

                        <div class="max-w-1/3 md:w-2/5 flex justify-start items-start">
                            <span class="text-lg text-neutral-500">
                                {item.number}
                            </span>
                        </div>

                        <div class="max-w-2/3 md:w-3/5 flex flex-col gap-2">
                            <span class="text-xl text-neutral">
                                {item.title}
                            </span>
                            <div class="flex flex-wrap items-center gap-2 md:gap-4 wrap-break-word">
                                {
                                
                                    item.tags.map((i, index) => (
                                        <span class="uppercase text-neutral font-light text-xs">
                                            {i}
                                        </span>
                                        <span>

                                            {
                                                index != 2 && (
                                                    <svg width="6" height="6" viewBox="0 0 6 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                        <circle cx="3" cy="3" r="3" fill="#333333"/>
                                                    </svg>
                                                )
                                            }

                                        </span>
                                    ))
                                
                                }
                            </div>
                            <span class="text-neutral max-sm:mt-4 text-sm md:text-desktop-p font-light md:opacity-0 md:max-h-0 md:overflow-hidden md:group-hover:opacity-100 group-hover:max-h-40 transition-all duration-500">
                                {item.description}
                            </span>
                        </div>
                        

                    </div>
                ))
            }
        </div>

        <div>
            <Button
                href="/services" 
                label="View Details" 
                classes="group flex justify-center items-center text-primary-orange font-light"
                
                >
                    <Image
                        src={Right}
                        alt="Icon"
                        slot="icon"
                        class="group-hover:translate-x-2 transition ease-in-out"
                    />
                </Button>

        </div>
    </div>

</section>

<script is:inline>

    if(window.innerWidth < 768){
        const cards = document.querySelectorAll('.card')

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach(entry => {
                    if(entry.isIntersecting){
                        entry.target.classList.add("bg-active")
                    }else{
                        entry.target.classList.remove("bg-active")
                    }
                })
            },
            {
                threshold: 0.8
            }
        );

        cards.forEach(card => observer.observe(card))
    };

    
</script>