---
import { Image } from "astro:assets";

import Rocket from "../../assets/icons/Rocket.svg"
import Right from "../../assets/icons/Right.svg"
import HeroImage from "../../assets/images/bg-grid.svg"

import Pill from "../atoms/Pill.astro";
import Button from "../atoms/Button.astro";


---


<section
  id="#"
  class="relative w-full h-screen px-5 overflow-hidden -mt-16"
>

    <picture class="absolute inset-0 w-full h-full md:hidden">
        <Image 
        src={HeroImage}
        alt="Hero"
        class="w-full h-full object-cover"
        loading="eager"
        />
  </picture>

    <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/images/hero-poster.png"
        class="absolute inset-0 w-full h-full object-cover -z-10 hidden md:block scale-105"
    >
    
    
        <source src="/hero-bg.webm" type="video/webm" media="(min-width: 768px)" />
        <source src="/hero-bg.mp4" type="video/mp4" media="(min-width: 768px)" />

    </video>

    <div class="relative z-40 max-w-4xl mx-auto flex flex-col md:justify-center md:items-center max-sm:space-y-6 space-y-10 mt-38 max-md:mt-20">
    
        <Pill label="Trusted by Startups & Freelancers">
            <Image
                slot={"icon"}
                src={Rocket}
                alt="Icon"
                class="w-8 h-8"
            />
        </Pill>

        <div class="flex flex-col justify-center items-center md:text-center space-y-6 max-sm:space-y-4">
            
            <div class="space-y-2">
                <h1 class="hero-title max-sm:text-mobile-h1 text-desktop-h1 font-medium leading-18 max-sm:leading-16 max-sm:font-semibold text-neutral">
                Websites 

                    <span class="text-primary-orange relative inline-block">
                        
                        That Work

                        <svg class="absolute -bottom-3 max-sm:-bottom-2 max-sm:left-1 left-2 w-full" width="284" height="18" viewBox="0 0 284 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M2.00037 15.5026C92.0004 -1.99726 191.5 -2.99731 282 15.5026" stroke="#F39C12" stroke-width="4" stroke-linecap="round"/>
                        </svg>


                    </span>

                    for You and Your Customers.
                </h1>

                <div class="lg:px-28">
                    <p class="hero-subtitle text-neutral font-light text-xl">
                    We build fast, responsive, and memorable websites designed to grow your business and make your ideas real.
                    </p>
                </div>

            </div>

            <div class="flex max-md:flex-col max-md:w-full gap-4">

                <Button
                href="#contact" 
                label="Get a free Quote" 
                classes="rounded-full px-6 py-3 flex justify-center items-center gap-2 bg-neutral text-neutral2 hover:bg-neutral/90 group">
                    <Image
                        src={Right}
                        alt="Icon"
                        slot="icon"
                        class="group-hover:translate-x-2 transition ease-in-out"
                    />
                </Button>

                <Button
                href="#services" 
                label="Our Services" 
                classes="rounded-full border border-neutral/20 px-6 py-3 flex justify-center items-center gap-2 bg-bg text-neutral shadow-sm hover:bg-primary-orange/10 group"/>
            </div>


        </div>
        
    </div>


</section>

<script>
import { heroAnimation } from "../../animations/Hero";
heroAnimation();

window.addEventListener('load', () => {
  const video = document.querySelector('video');
  if (video) {
    video.load();  // Reloads sources fresh
    video.play().catch(error => console.error('Video playback error:', error));  // Handles any autoplay policy issues
  }
});
</script>