---
import Layout from '@layouts/Layout.astro';
import Button from "@ui/Button.astro"
---

<Layout title="404 - Page Not Found" description="The page you are looking for does not exist. Return to the homepage of Fayda Studio.">

    <div class="flex flex-col justify-center items-center px-5 text-center my-8 md:my-32">
        <h1 class="text-mobile-h1 md:text-desktop-h1 font-bold text-primary-orange mb-4">404</h1>
        <h2 class="text-2xl md:text-4xl font-semibold mb-1">Page Not Found</h2>
        <p class="text-lg md:text-xl mb-8">Sorry, the page you are looking for does not exist.</p>

        <Button
            href="/#"
            label="Back to Home"
            classes="rounded-full px-6 py-3 flex justify-center items-center gap-2 bg-neutral text-neutral2 hover:bg-neutral/90"
        />

    </div>

</Layout>

