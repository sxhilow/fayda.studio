---
import Layout from '@layouts/Layout.astro';
import Button from "@ui/Button.astro"
---

<Layout title="404 - Page Not Found" description="The page you are looking for does not exist. Return to the homepage of Fayda Studio.">

    <div class="flex flex-col justify-center min-h-screen items-center px-5 gap-8 text-center">

        <div>
            <h1 class="text-h1 text-brand-red mb-4">404</h1>
            <h2 class="text-h3 mb-1 text-brand-surface">Page Not Found</h2>
            <p class="text-brand-surface">Sorry, the page you are looking for does not exist.</p>
        </div>

        <Button
            href="/"
            label="Back to Home"
        />

    </div>

</Layout>

